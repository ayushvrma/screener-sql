{
  "meta": {
    "source": "screener.in",
    "compiled_on": "2026-07-08",
    "notes": [
      "Variable names are case-insensitive on screener.in but are typically written in Sentence Case",
      "Screen queries are inequalities; custom ratios are formulas (no inequality)",
      "RHS of any comparison may be a literal number OR another variable OR an arithmetic expression",
      "The '%' suffix on numbers is accepted and ignored (e.g., 22% == 22)"
    ]
  },
  "operators": {
    "comparison": [">", "<", ">=", "<=", "="],
    "logical": ["AND", "OR"],
    "grouping": ["(", ")"],
    "arithmetic": ["+", "-", "*", "/"]
  },
  "functions": [
    { "name": "If", "signature": "If(condition, value_if_true, value_if_false)", "purpose": "Excel-style conditional; used to build score-like ratios" },
    { "name": "power", "signature": "power(base, exponent)", "purpose": "Exponent" },
    { "name": "least", "signature": "least(a, b, ...)", "purpose": "Minimum of arguments" },
    { "name": "abs", "signature": "abs(x)", "purpose": "Absolute value" },
    { "name": "sqrt", "signature": "sqrt(x)", "purpose": "Square root" },
    { "name": "log", "signature": "log(x)", "purpose": "Natural log" },
    { "name": "coalesce", "signature": "coalesce(a, b, ...)", "purpose": "First non-null argument" }
